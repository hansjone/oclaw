{
  "mcpServers": {
    "triliumnext-mcp": {
      "command": "npx",
      "args": ["-y", "triliumnext-mcp"],
      "env": {
        "TRILIUM_API_URL": "http://127.0.0.1:37840/etapi",
        "TRILIUM_API_TOKEN": "<paste-from-trilium-settings>",
        "PERMISSIONS": "READ;WRITE",
        "VERBOSE": "false"
      }
    }
  }
}
