# -----------------------------------------------------------------------------
AIA_ATTACHMENT_ACL_STRICT=
AIA_MAX_ATTACHMENT_BYTES=

# -----------------------------------------------------------------------------
# 十二、路由与运行时日志
# -----------------------------------------------------------------------------
# 详见 docs/LOGGING.md。根目录默认：<db_path 父目录>/logs（常为 data/logs/）。
AIA_OCLAW_ROUTER_MODE=
AIA_RUNTIME_LOG_DIR=
# OCLAW_DESKTOP_LOG_ROOT              可选；Electron 写 desktop.log/backend.log 的根；start_desktop.ps1 会设为与 AIA_RUNTIME_LOG_DIR 相同。
OCLAW_DESKTOP_LOG_ROOT=
# OCLAW_LOG_LEVEL / AIA_LOG_LEVEL    应用与 uvicorn 文件日志级别，默认 INFO。
# OCLAW_LOG_MAX_BYTES                 单文件上限（字节），默认 20971520（20 MiB）。
# OCLAW_LOG_BACKUP_COUNT              轮转保留份数，默认 5。
# AIA_LOG_TO_FILE                     设为 0/false/off 时不写 app/*.log（pytest 也会跳过文件 handler）。
# OCLAW_HOOK_LOG_USE_STATE_DIR        设为 1/true 时，command-logger / boot-md 改回 ~/.oclaw/logs（或 OCLAW_STATE_DIR/logs）；默认写入运行日志根下 hooks/。
OCLAW_LOG_LEVEL=
OCLAW_LOG_MAX_BYTES=
OCLAW_LOG_BACKUP_COUNT=
AIA_LOG_TO_FILE=
OCLAW_HOOK_LOG_USE_STATE_DIR=

# -----------------------------------------------------------------------------
# 十三、RAG / 记忆
# -----------------------------------------------------------------------------
AIA_RAG_MODE=
AIA_RAG_EMBEDDING_MODE=
AIA_MEMORY_EPISODIC_TTL_DAYS=
MEMORY_EPISODIC_TTL_DAYS=

